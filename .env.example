PORT=4000
NODE_ENV=development

# Stellar network (testnet | mainnet)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Contract IDs — printed by shieldfund-contracts/scripts/deploy-testnet.sh
TREASURY_VAULT_CONTRACT_ID=
STREAMING_CONTRACT_ID=
PROOF_REGISTRY_CONTRACT_ID=

# SQLite database path (default: ./data/shieldfund.db)
# DB_PATH=./data/shieldfund.db

# Optional: Pinata IPFS for campaign metadata storage
PINATA_API_KEY=
PINATA_SECRET_KEY=
